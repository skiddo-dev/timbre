    "@types/node": "^24.0.0",
    "megajs": "^1.3.10",
    "svelte": "^5.16.0",
    "svelte-check": "^4.1.1",
    "typescript": "^5.7.2",
    "vite": "^5.4.11"
  },
  "dependencies": {
    "music-metadata": "^11.13.0"
  }
