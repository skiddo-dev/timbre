# Timbre — a no-subscription, self-hosted music player. Copy to .env and edit.

# SQLite library database (created on first run).
DATABASE_PATH=data/timbre.db

# Folder Timbre indexes. Point this at your music. REQUIRED to see anything.
MUSIC_DIR=

# Where fetched cover art / artist images are cached.
ART_CACHE_DIR=data/art

# Optional: only used by the loudness/ReplayGain scan (M4). If ffmpeg isn't on
# PATH the scan still runs — it just skips loudness analysis for that file.
FFMPEG_BIN=ffmpeg

# Free metadata enrichment (MusicBrainz / Cover Art Archive). A real
# User-Agent is REQUIRED by MusicBrainz or you get rate-limited / blocked.
MUSICBRAINZ_UA=Timbre/0.1 ( https://github.com/skiddo-dev/timbre )
# Set to 1 for offline tests — enrichment returns canned data instead of HTTP.
# TIMBRE_FAKE_ENRICH=1

# Local LLM (Ollama / LM Studio) — powers the discovery brain (auto-tagging, radio,
# natural-language Ask). Privacy-first: no cloud fallback. If unset, those features
# fall back to deterministic heuristics so they still work with no model.
LOCAL_LLM_BASE_URL=http://127.0.0.1:11434/v1
LOCAL_LLM_MODEL=llama3.1:8b
# Set to 1 for offline tests — discovery uses heuristics/fixtures instead of the model.
# TIMBRE_FAKE_LLM=1

# Snapcast multi-room (M6). Point at a running snapserver to manage zones from /zones.
# Leave SNAPCAST_HOST empty to disable multi-room entirely.
# SNAPCAST_HOST=127.0.0.1
SNAPCAST_RPC_PORT=1705
# FIFO that snapserver reads its "Timbre" stream from; the audio feeder writes PCM here.
SNAPCAST_FIFO=/tmp/snapfifo

# Last.fm scrobbling (opt-in — the only cloud connection in Timbre). Create an API
# account at https://www.last.fm/api/account/create, then connect your profile from
# Settings → Last.fm. Leave these empty to disable scrobbling entirely.
# LASTFM_API_KEY=
# LASTFM_API_SECRET=
# Set to 1 for offline tests — auth + scrobble submission are stubbed (no HTTP).
# TIMBRE_FAKE_LASTFM=1

# Apple Music subscription (opt-in — a metadata/library source, NEVER a player).
# It enriches local albums (artwork, genres, editorial) and mirrors your Apple
# library + playlists onto local files; catalog-only tracks become deep-link rows.
# Needs an Apple Developer Program membership to create a MusicKit key (.p8):
#   - APPLE_MUSIC_TEAM_ID   your 10-char Apple Developer Team ID
#   - APPLE_MUSIC_KEY_ID    the MusicKit key's Key ID
#   - APPLE_MUSIC_PRIVATE_KEY  the .p8 file contents (PEM; \n-escaped is fine), OR
#   - APPLE_MUSIC_PRIVATE_KEY_PATH  a path to the .p8 file
# Connect the subscription itself from Settings → Apple Music. Leave empty to disable.
# APPLE_MUSIC_TEAM_ID=
# APPLE_MUSIC_KEY_ID=
# APPLE_MUSIC_PRIVATE_KEY=
# APPLE_MUSIC_PRIVATE_KEY_PATH=
# APPLE_MUSIC_STOREFRONT=us
# Set to 1 for offline tests — the developer token, catalog and library are stubbed.
# TIMBRE_FAKE_APPLEMUSIC=1

# ── Usenet (NZB) acquisition ──────────────────────────────────────────────────
# Search Newznab indexers, grab releases, and download them into MUSIC_DIR/_usenet
# for the scanner. Indexers are added from the /usenet page (stored in the DB).
# Everything here is optional; without a download client, search still works.
#
# Primary engine — a SABnzbd (or NZBGet) download client. It does the heavy lifting
# (NNTP fetch + PAR2 repair + unrar), which is what real music posts need. Point its
# completed/category folder INTO MUSIC_DIR so finished albums land where the scan
# sees them. NZBGet exposes a near-identical API.
# SABNZBD_URL=http://127.0.0.1:8080
# SABNZBD_API_KEY=
#
# Fallback engine — Timbre's built-in NNTP + yEnc downloader, used when no SABnzbd
# client is set. Good for simple, directly-posted audio; it has no PAR2/unrar of its
# own (extract.ts shells out to par2/unrar/7z only if they're on PATH). Point these
# at your Usenet provider:
# NNTP_HOST=news.example-provider.com
# NNTP_PORT=563
# NNTP_SSL=1            # 1/true = TLS (563), 0/false = plaintext (119)
# NNTP_USER=
# NNTP_PASS=
