# Timbre — a no-subscription, self-hosted music player. Copy to .env and edit.

# SQLite library database (created on first run).
DATABASE_PATH=data/timbre.db

# Folder Timbre indexes. Point this at your music. REQUIRED to see anything.
MUSIC_DIR=

# Where fetched cover art / artist images are cached.
ART_CACHE_DIR=data/art

# Optional: only used by the loudness/ReplayGain scan (M4). If ffmpeg isn't on
# PATH the scan still runs — it just skips loudness analysis for that file.
FFMPEG_BIN=ffmpeg

# Free metadata enrichment (MusicBrainz / Cover Art Archive). A real
# User-Agent is REQUIRED by MusicBrainz or you get rate-limited / blocked.
MUSICBRAINZ_UA=Timbre/0.1 ( https://github.com/skiddo-dev/timbre )
# Set to 1 for offline tests — enrichment returns canned data instead of HTTP.
# TIMBRE_FAKE_ENRICH=1

# Local LLM (Ollama / LM Studio) — wired but UNUSED until the M7 discovery brain.
# Privacy-first: there is deliberately no cloud fallback.
LOCAL_LLM_BASE_URL=http://127.0.0.1:11434/v1
LOCAL_LLM_MODEL=llama3.1:8b
